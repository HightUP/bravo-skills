# ═════════════════════════════════════════════════════════════
# espionar-concorrente-full · variáveis de ambiente
# ═════════════════════════════════════════════════════════════
# Setup:
#   cp .env.example .env
#   edita o .env com seus valores
# Atenção: NÃO commite o .env (já está no .gitignore)
# Sem aspas nos valores. Sem espaço em volta do `=`.
# ═════════════════════════════════════════════════════════════
# Versão FULL (Mentoria Bravo): baixa ativos + transcreve vídeos +
# descreve imagens com vision + gera HTML report navegável.
# ═════════════════════════════════════════════════════════════


# ── Onde salvar ──────────────────────────────────────────────

# OBSIDIAN_VAULT_PATH
# Caminho absoluto pra criar `concorrentes/<nome>/<data>/` com
# os ativos + `report.html` + `insights.md`.
# SEM `/` no final. Sem `~`. Sem aspas.
# Exemplo: /Users/voce/Documents/obsidian-bravo
OBSIDIAN_VAULT_PATH=/Users/voce/Documents/obsidian-bravo


# ── Playwright ───────────────────────────────────────────────

# PLAYWRIGHT_HEADLESS
# Browser invisível ou aparecendo na tela
# Valores: `true` (default — invisível) ou `false` (mostra browser)
# Lowercase, sem aspas.
PLAYWRIGHT_HEADLESS=true


# ── IA (escolha UMA) ─────────────────────────────────────────
# Pra transcrição de áudio dos vídeos + descrição visual das imagens.
# Gemini é ~5x mais barato pra esse uso. Recomendado.

# GEMINI_API_KEY
# Pega em: aistudio.google.com → Get API key → Create
# Formato: começa com `AIzaSy` + ~33 chars
# Cuidados: sem aspas, sem espaço, copie inteiro
# Exemplo: GEMINI_API_KEY=AIzaSyD...
GEMINI_API_KEY=

# OPENAI_API_KEY (alternativa)
# Pega em: platform.openai.com → API keys → Create
# Formato: começa com `sk-` ou `sk-proj-`
# Cuidados: sem aspas, sem espaço
# Use a Gemini se possível (custo). Se preferir GPT-4o + Whisper, descomenta:
# OPENAI_API_KEY=sk-proj-...
