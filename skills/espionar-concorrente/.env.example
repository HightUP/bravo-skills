# ═════════════════════════════════════════════════════════════
# espionar-concorrente · variáveis de ambiente
# ═════════════════════════════════════════════════════════════
# Setup:
#   cp .env.example .env
#   edita o .env com seus valores
# Atenção: NÃO commite o .env (já está no .gitignore)
# Sem aspas nos valores. Sem espaço em volta do `=`.
# ═════════════════════════════════════════════════════════════
# Versão LITE — só baixa ativos brutos (sem análise IA).
# Versão FULL (com transcrição de vídeo + vision + HTML report)
# está disponível na Mentoria Bravo: areadebravo.com.br/mentoria
# ═════════════════════════════════════════════════════════════


# ── Onde salvar ──────────────────────────────────────────────

# OBSIDIAN_VAULT_PATH
# Caminho absoluto onde criar `concorrentes/<nome>/<data>/`.
# Pode ser o vault Obsidian ou outra pasta qualquer.
# SEM `/` no final. Sem `~`. Sem aspas.
# Exemplo: /Users/voce/Documents/obsidian-bravo
OBSIDIAN_VAULT_PATH=/Users/voce/Documents/obsidian-bravo


# ── Playwright ───────────────────────────────────────────────

# PLAYWRIGHT_HEADLESS
# Define se o navegador abre invisível ou aparece na tela
# Valores: `true` (default — invisível) ou `false` (mostra browser)
# Cuidados: lowercase, sem aspas
# Quando usar `false`: pra debug, ver o que tá rolando
# Quando usar `true`: produção, mais rápido, sem distração
PLAYWRIGHT_HEADLESS=true
